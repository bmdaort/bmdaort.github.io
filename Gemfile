source "https://rubygems.org"

# Use the github-pages gem so the site builds locally the same way GitHub Pages
# builds it in production. Bumping this gem tracks GitHub Pages' supported
# versions of Jekyll and its whitelisted plugins.
gem "github-pages", group: :jekyll_plugins

group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-sitemap"
  gem "jekyll-seo-tag"
end

# Windows / macOS timezone data and file-watching helpers.
gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]
gem "wdm", "~> 0.1.1", platforms: [:mingw, :mswin, :x64_mingw]
gem "webrick", "~> 1.8"
